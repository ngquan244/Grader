# Teaching Assistant Grader - Environment Configuration

# Server settings
HOST=127.0.0.1
PORT=8000
DEBUG=true

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000", "http://localhost:5173", "http://127.0.0.1:5173"]

# ===== LLM Provider Settings =====
# Choose provider: "groq" (production) or "ollama" (development only)
LLM_PROVIDER=groq

# ===== Ollama Settings (Development only — NOT supported in production) =====
# OLLAMA_MODEL=llama3.1:latest
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TEMPERATURE=0.3

# ===== Groq Cloud Settings =====
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Fallback to Ollama if Groq fails (must be false in production)
GROQ_FALLBACK_TO_OLLAMA=false

# AI Model settings (legacy, for other parts of the app)
DEFAULT_MODEL=llama3.1:latest
MAX_ITERATIONS=10
TEMPERATURE=0.3

# Email settings
EMAIL_RECEIVER=your-email@example.com
EMAIL_USER=your-smtp-email@gmail.com
EMAIL_PASSWORD=your-app-password

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=grader_user
POSTGRES_PASSWORD=your_secure_database_password_here
POSTGRES_DB=grader_db

# =============================================================================
# JWT Configuration (Authentication)
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_characters_long
JWT_REFRESH_SECRET_KEY=your_separate_refresh_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Login Security (Brute-force protection)
# =============================================================================
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_LOCKOUT_DURATION_SECONDS=900
TOKEN_BLACKLIST_REDIS_DB=2

# =============================================================================
# Encryption Configuration (for Canvas token storage)
# =============================================================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# =============================================================================
# Password Hashing Configuration
# =============================================================================
PASSWORD_HASH_ALGORITHM=argon2
BCRYPT_ROUNDS=12

# =============================================================================
# Redis Configuration (Required for Celery background jobs)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# Celery Worker Configuration
# =============================================================================
# Rate limits (requests per minute)
LLM_RATE_LIMIT=10
CANVAS_RATE_LIMIT=50

# Worker concurrency per queue
WORKER_CONCURRENCY_RAG=2
WORKER_CONCURRENCY_LLM=1
WORKER_CONCURRENCY_CANVAS=4
WORKER_CONCURRENCY_MISC=2

# Flower monitoring dashboard (optional)
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# Database settings (SQL Server - Legacy)
SQL_SERVER_CONN_STR=Driver={ODBC Driver 17 for SQL Server};Server=YOUR_SERVER;Database=AI_Agent;Trusted_Connection=yes;Encrypt=no;

# =============================================================================
# Production Domain (required for docker-compose.prod.yml)
# =============================================================================
# PRODUCTION_DOMAIN=grader.example.com

# =============================================================================
# Signup Configuration
# =============================================================================
# Mode: "open" (anyone can register) | "invite" (requires invite code) | "closed" (no registration)
SIGNUP_MODE=open
# Required when SIGNUP_MODE=invite (min 16 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SIGNUP_INVITE_CODE=

# =============================================================================
# CORS Configuration (Production)
# =============================================================================
# For production, set explicitly:
# CORS_ORIGINS=["https://grader.example.com"]
