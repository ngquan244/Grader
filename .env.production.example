# =============================================================================
# Grader — Production Environment Template
# =============================================================================
# 1. Copy this file:  cp .env.production.example .env.production
# 2. Fill in ALL values marked with CHANGE_ME / your-...
# 3. Generate secrets:
#      python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#      python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 4. Deploy:  scp .env.production root@VPS_IP:/root/grader/.env
# =============================================================================

# === Domain ===
PRODUCTION_DOMAIN=grader.yourdomain.com
LETSENCRYPT_EMAIL=your-email@example.com

# === Deployment Provider ===
# auto = detect automatically (GCP metadata server check)
# hetzner = Hetzner VPS (uses UFW firewall)
# gcp = GCP Compute Engine (firewall managed via VPC rules)
DEPLOY_PROVIDER=auto

# === Environment ===
ENVIRONMENT=production
DEBUG=false

# === LLM (Groq only in production) ===
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_FALLBACK_TO_OLLAMA=false

# === PostgreSQL ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=grader_user
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
POSTGRES_DB=grader_db

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# === JWT Authentication ===
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
JWT_REFRESH_SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Encryption (Canvas token storage) ===
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# === Login Security ===
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_LOCKOUT_DURATION_SECONDS=900
TOKEN_BLACKLIST_REDIS_DB=2

# === Signup ===
SIGNUP_MODE=invite
SIGNUP_INVITE_CODE=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
INVITE_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# === CORS ===
CORS_ORIGINS=["https://grader.yourdomain.com"]

# === Celery Workers ===
LLM_RATE_LIMIT=10
CANVAS_RATE_LIMIT=50
WORKER_CONCURRENCY_RAG=2
WORKER_CONCURRENCY_LLM=1
WORKER_CONCURRENCY_CANVAS=4
WORKER_CONCURRENCY_MISC=2

# === Flower Monitoring ===
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
